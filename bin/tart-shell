#!/usr/bin/env ruby
# frozen_string_literal: true

require "open3"
require "shellwords"
require "time"

ROOT = File.expand_path("..", __dir__)
RUN_ID = Time.now.strftime("%Y%m%d%H%M%S")
BASE_VM = ENV.fetch("TART_BASE_VM", "clean-tahoe")
BASE_IMAGE = ENV.fetch("TART_BASE_IMAGE", "ghcr.io/cirruslabs/macos-tahoe-vanilla:latest")
VM = ARGV.first || ENV.fetch("TART_MANUAL_VM", "dotfiles-manual-#{RUN_ID}")
SHARE_NAME = ENV.fetch("TART_SHARE_NAME", "dotfiles-next")
SSH_USER = ENV.fetch("TART_SSH_USER", "admin")
SSH_PASSWORD = ENV.fetch("TART_SSH_PASSWORD", "admin")
NO_GRAPHICS = ENV.fetch("TART_NO_GRAPHICS", "1") != "0"
SSH_OPTIONS = %w[
  -o StrictHostKeyChecking=no
  -o UserKnownHostsFile=/dev/null
  -o LogLevel=ERROR
]

def log(message)
  puts "== #{message} =="
end

def run(*cmd)
  log cmd.shelljoin
  system(*cmd) || raise("command failed: #{cmd.shelljoin}")
end

def capture(*cmd)
  stdout, stderr, status = Open3.capture3(*cmd)
  raise "command failed: #{cmd.shelljoin}\n#{stderr}" unless status.success?

  stdout
end

def local_vms
  capture("tart", "list", "--source", "local", "--quiet").lines.map(&:chomp)
end

def vm_exists?(name)
  local_vms.include?(name)
end

def ensure_base_vm
  return if vm_exists?(BASE_VM)

  run "tart", "clone", BASE_IMAGE, BASE_VM
end

def ensure_manual_vm
  if vm_exists?(VM)
    log "Using existing VM: #{VM}"
  else
    ensure_base_vm
    run "tart", "clone", BASE_VM, VM
  end
end

def wait_for_ip
  log "Waiting for #{VM} IP..."

  120.times do |attempt|
    ip = capture("tart", "ip", VM).strip
    return ip unless ip.empty?
  rescue StandardError
    puts "  still waiting for IP... (#{attempt + 1}/120)" if (attempt + 1) % 10 == 0
    sleep 2
  end

  raise "timed out waiting for #{VM} IP"
end

def expect_available?
  system("command -v expect >/dev/null 2>&1")
end

def ssh_command(ip, command = nil)
  command ? ["ssh", "-tt", *SSH_OPTIONS, "#{SSH_USER}@#{ip}", command] : ["ssh", "-tt", *SSH_OPTIONS, "#{SSH_USER}@#{ip}"]
end

def expect_ssh_command(ip, command = nil)
  ssh = ssh_command(ip, command).shelljoin
  script = <<~EXPECT
    set timeout -1
    log_user 0
    spawn /bin/sh -c #{ssh.shellescape}
    expect {
      -nocase "password:" {
        send -- "$env(TART_SSH_PASSWORD)\r"
        log_user 1
      }
      eof {
        catch wait result
        exit [lindex $result 3]
      }
    }
    interact
    catch wait result
    exit [lindex $result 3]
  EXPECT

  ["expect", "-c", script]
end

def ssh_system(ip, command = nil, **kwargs)
  if SSH_PASSWORD.empty?
    system(*ssh_command(ip, command), **kwargs)
  else
    raise "TART_SSH_PASSWORD is set, but expect is not available" unless expect_available?

    system({ "TART_SSH_PASSWORD" => SSH_PASSWORD }, *expect_ssh_command(ip, command), **kwargs)
  end
end

def wait_for_ssh(ip)
  log "Waiting for SSH on #{ip}..."

  120.times do |attempt|
    return if ssh_system(ip, "true", out: File::NULL, err: File::NULL)

    puts "  still waiting for SSH... (#{attempt + 1}/120)" if (attempt + 1) % 10 == 0
    sleep 2
  end

  raise "timed out waiting for SSH on #{ip}"
end

def start_vm
  args = ["tart", "run"]
  args << "--no-graphics" if NO_GRAPHICS
  args << "--dir=#{SHARE_NAME}:#{ROOT}"
  args << VM

  log args.shelljoin
  log_path = File.join(ROOT, "tmp-tart-#{VM}.log")
  log "VM log: #{log_path}"
  log_file = File.open(log_path, "a")
  pid = spawn(*args, out: log_file, err: [:child, :out])
  Process.detach(pid)
end

begin
  run "tart", "--version"
  ensure_manual_vm
  start_vm
  ip = wait_for_ip
  wait_for_ssh(ip)

  log "Shared repo path in VM: /Volumes/My Shared Files/#{SHARE_NAME}"
  log "SSH user: #{SSH_USER}"
  log "When done, stop/delete with: tart stop #{VM.shellescape}; tart delete #{VM.shellescape}"

  if SSH_PASSWORD.empty?
    exec(*ssh_command(ip))
  else
    exec({ "TART_SSH_PASSWORD" => SSH_PASSWORD }, *expect_ssh_command(ip))
  end
rescue StandardError => e
  warn e.message
  exit 1
end
