#!/usr/bin/env ruby
# frozen_string_literal: true

require "open3"
require "shellwords"
require "time"

ROOT = File.expand_path("..", __dir__)
RUN_ID = Time.now.strftime("%Y%m%d%H%M%S")
BASE_VM = ENV.fetch("TART_BASE_VM", "clean-tahoe")
BASE_IMAGE = ENV.fetch("TART_BASE_IMAGE", "ghcr.io/cirruslabs/macos-tahoe-vanilla:latest")
SUITE_BASE_VM = ENV.fetch("TART_SUITE_BASE_VM", "dotfiles-suite-base-#{RUN_ID}")
TEST_VM_PREFIX = ENV.fetch("TART_TEST_VM_PREFIX", "dotfiles-test-#{RUN_ID}")
SSH_USER = ENV.fetch("TART_SSH_USER", "admin")
SSH_PASSWORD = ENV.fetch("TART_SSH_PASSWORD", "admin")
SHARE_NAME = ENV.fetch("TART_SHARE_NAME", "dotfiles-next")
REMOTE_REPO = ENV.fetch("TART_REMOTE_REPO", "/Volumes/My Shared Files/#{SHARE_NAME}")
BOOTSTRAP_INSTALL_FLAGS = ENV.fetch("TART_BOOTSTRAP_INSTALL_FLAGS", "--non-interactive --verbose")
KEEP_VM = ENV["TART_KEEP_VM"] == "1"
NO_GRAPHICS = ENV.fetch("TART_NO_GRAPHICS", "1") != "0"
SSH_OPTIONS = %w[
  -o StrictHostKeyChecking=no
  -o UserKnownHostsFile=/dev/null
  -o LogLevel=ERROR
]

$created_vms = []
$running_vms = []
$failed = false

def log(message)
  puts "== #{message} =="
end

def command_for_log(cmd)
  if cmd.first.is_a?(Hash)
    env = cmd.first.map { |key, value| "#{key}=#{value.shellescape}" }.join(" ")
    [env, cmd.drop(1).shelljoin].reject(&:empty?).join(" ")
  else
    cmd.shelljoin
  end
end

def run(*cmd)
  log command_for_log(cmd)
  system(*cmd) || raise("command failed: #{command_for_log(cmd)}")
end

def capture(*cmd)
  stdout, stderr, status = Open3.capture3(*cmd)
  raise "command failed: #{cmd.shelljoin}\n#{stderr}" unless status.success?

  stdout
end

def local_vms
  capture("tart", "list", "--source", "local", "--quiet").lines.map(&:chomp)
end

def vm_exists?(name)
  local_vms.include?(name)
end

def clone_vm(source, destination)
  raise "VM already exists: #{destination}" if vm_exists?(destination)

  run "tart", "clone", source, destination
  $created_vms << destination
end

def ensure_base_vm
  return if vm_exists?(BASE_VM)

  clone_vm(BASE_IMAGE, BASE_VM)
end

def wait_for_ip(vm)
  log "Waiting for #{vm} IP..."

  120.times do |attempt|
    ip = capture("tart", "ip", vm).strip
    return ip unless ip.empty?
  rescue StandardError
    puts "  still waiting for IP... (#{attempt + 1}/120)" if (attempt + 1) % 10 == 0
    sleep 2
  end

  raise "timed out waiting for #{vm} IP"
end

def expect_available?
  system("command -v expect >/dev/null 2>&1")
end

def ssh_command(ip, command)
  ["ssh", *SSH_OPTIONS, "#{SSH_USER}@#{ip}", command]
end

def remote_bash_command(command)
  encoded = [command].pack("m0")
  "printf %s #{encoded.shellescape} | /usr/bin/base64 -D | /bin/bash"
end

def expect_ssh_command(ip, command)
  ssh = ssh_command(ip, remote_bash_command(command)).shelljoin
  script = <<~EXPECT
    set timeout -1
    log_user 0
    spawn /bin/sh -c #{ssh.shellescape}
    expect {
      -nocase "password:" {
        send -- "$env(TART_SSH_PASSWORD)\r"
        log_user 1
      }
      eof {
        catch wait result
        exit [lindex $result 3]
      }
    }
    expect eof
    catch wait result
    exit [lindex $result 3]
  EXPECT

  ["expect", "-c", script]
end

def ssh(ip, command)
  if SSH_PASSWORD.empty?
    run(*ssh_command(ip, command))
  else
    raise "TART_SSH_PASSWORD is set, but expect is not available" unless expect_available?

    log "ssh #{SSH_USER}@#{ip} <remote script>"
    system({ "TART_SSH_PASSWORD" => SSH_PASSWORD }, *expect_ssh_command(ip, command)) || raise("command failed: ssh #{SSH_USER}@#{ip} <remote script>")
  end
end

def wait_for_ssh(ip)
  log "Waiting for SSH on #{ip}..."

  120.times do |attempt|
    if SSH_PASSWORD.empty?
      return if system(*ssh_command(ip, "true"), out: File::NULL, err: File::NULL)
    elsif expect_available?
      return if system({ "TART_SSH_PASSWORD" => SSH_PASSWORD }, *expect_ssh_command(ip, "true"), out: File::NULL, err: File::NULL)
    end

    puts "  still waiting for SSH... (#{attempt + 1}/120)" if (attempt + 1) % 10 == 0
    sleep 2
  end

  raise "timed out waiting for SSH on #{ip}"
end

def start_vm(vm)
  run_args = ["tart", "run"]
  run_args << "--no-graphics" if NO_GRAPHICS
  run_args << "--dir=#{SHARE_NAME}:#{ROOT}"
  run_args << vm

  log run_args.shelljoin
  vm_log = File.open(File.join(ROOT, "tmp-tart-#{vm}.log"), "w")
  spawn(*run_args, out: vm_log, err: [:child, :out])
  $running_vms << vm

  ip = wait_for_ip(vm)
  log "#{vm} IP: #{ip}"
  wait_for_ssh(ip)
  ip
end

def stop_vm(vm)
  system("tart", "stop", vm, out: File::NULL, err: File::NULL)
  $running_vms.delete(vm)
end

def delete_vm(vm)
  system("tart", "delete", vm, out: File::NULL, err: File::NULL)
  $created_vms.delete(vm)
end

def sudo_prewarm_script
  return "" if SSH_PASSWORD.empty?

  <<~SH
    echo '== remote: validate sudo =='
    printf '%s\n' #{SSH_PASSWORD.shellescape} | sudo -S -p '' -v
  SH
end

def shellenv_script
  <<~SH
    if [ -x /opt/homebrew/bin/brew ]; then
      eval "$(/opt/homebrew/bin/brew shellenv)"
    elif [ -x /usr/local/bin/brew ]; then
      eval "$(/usr/local/bin/brew shellenv)"
    fi
  SH
end

def dry_run_script
  <<~SH
    set -euo pipefail
    cd #{REMOTE_REPO.shellescape}

    echo '== remote: dry-run preview =='
    ./bootstrap --dry-run --verbose link

    echo '== remote: verify dry-run did not link dotfiles =='
    test ! -L "$HOME/.zprofile"
    test ! -L "$HOME/.gitconfig"
    test ! -L "$HOME/.config/ghostty/config.ghostty"
  SH
end

def full_install_script
  <<~SH
    set -euo pipefail
    cd #{REMOTE_REPO.shellescape}

    #{sudo_prewarm_script}

    echo '== remote: install =='
    ./bootstrap #{BOOTSTRAP_INSTALL_FLAGS} link

    echo '== remote: load Homebrew shellenv for verification =='
    #{shellenv_script}

    echo '== remote: tests =='
    ./bin/test

    echo '== remote: doctor after install =='
    ./bootstrap doctor

    echo '== remote: idempotency rerun =='
    ./bootstrap #{BOOTSTRAP_INSTALL_FLAGS} link

    echo '== remote: verification =='
    command -v brew
    command -v mise
    mise exec --cd . -- ruby -v
    test -L "$HOME/.zprofile"
    test -L "$HOME/.gitconfig"
    test -L "$HOME/.gitignore"
    test -L "$HOME/.zshrc"
    test -L "$HOME/.tmux.conf"
    test -L "$HOME/.tmux.mac.conf"
    test -L "$HOME/.config/ghostty/config.ghostty"
  SH
end

def run_case(name, script)
  vm = "#{TEST_VM_PREFIX}-#{name}"
  clone_vm(SUITE_BASE_VM, vm)
  ip = start_vm(vm)
  ssh(ip, script)
  stop_vm(vm)
  delete_vm(vm) unless KEEP_VM
  log "Tart case passed: #{name}"
rescue StandardError
  $failed = true
  warn "Keeping #{vm} for debugging."
  raise
end

def cleanup
  return if KEEP_VM

  if $failed
    warn "Keeping Tart VMs for debugging: #{$created_vms.join(", ")}" unless $created_vms.empty?
    return
  end

  $running_vms.dup.each { stop_vm(it) }
  $created_vms.reverse_each { delete_vm(it) }
end

at_exit { cleanup }

begin
  run "tart", "--version"
  ensure_base_vm
  clone_vm(BASE_VM, SUITE_BASE_VM)

  run_case("dry-run", dry_run_script)
  run_case("full-install", full_install_script)

  log "Tart test suite passed"
rescue StandardError => e
  $failed = true
  warn e.message
  exit 1
end
