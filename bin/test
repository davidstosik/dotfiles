#!/usr/bin/env sh
set -eu

ROOT=$(CDPATH= cd -- "$(dirname -- "$0")/.." && pwd)

if [ -z "${DOTFILES_TEST_UNDER_MISE:-}" ] && command -v mise >/dev/null 2>&1; then
  exec env DOTFILES_TEST_UNDER_MISE=1 mise exec --cd "$ROOT" -- "$0" "$@"
fi

find "$ROOT/test" -name '*_test.rb' -print | sort | while IFS= read -r test_file; do
  ruby -I"$ROOT/lib" "$test_file"
done
